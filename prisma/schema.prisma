generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Siswa {
  id              Int      @id @default(autoincrement())
  namaLengkap     String
  nism            String
  nisn            String
  nik             String
  tempatLahir     String
  tanggalLahir    DateTime
  tingkatRombel   String
  umur            Int
  status          String
  jenisKelamin    String
  alamat          String
  noTelepon       String
  kebutuhanKhusus String
  disabilitas     String
  nomorKipPip     String
  namaAyah        String
  namaIbu         String
  nomorKK         String
  tahunAjaran     String?  // Tahun ajaran saat kenaikan kelas terakhir
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("siswa")
}

model Alumni {
  id              Int      @id @default(autoincrement())
  namaLengkap     String
  nism            String
  nisn            String
  nik             String
  tempatLahir     String
  tanggalLahir    DateTime
  umur            Int
  jenisKelamin    String
  alamat          String
  noTelepon       String
  kebutuhanKhusus String
  disabilitas     String
  nomorKipPip     String
  namaAyah        String
  namaIbu         String
  nomorKK         String
  tahunLulus      String   // Tahun ajaran kelulusan, contoh: "2025/2026"
  createdAt       DateTime @default(now())

  @@map("alumni")
}
model Guru {
  id                  Int      @id @default(autoincrement())
  namaLengkap         String
  nik                 String   @unique
  nuptk               String?  @unique
  pegid               String?
  npk                 String?
  // Tambahin '?' biar kalo Excel kosong gak error
  jenisKelamin        String?
  tempatLahir         String?
  tanggalLahir        DateTime? 
  umur                Int?
  alamat              String?
  kualifikasiAkademik String?
  tahunLulus          Int?
  statusSertifikasi   String?
  tahunSertifikasi    Int?
  statusImpasing      String?
  nrg                 String?
  tmt                 String?
  noSkAwal            String?
  masaKerja           String?
  tugasTambahan       String?
  nomorHandphone      String?
  email               String?
  noRekening          String?
  namaIbuKandung      String?
  status              String   @default("Aktif")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("guru")
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  password    String 
  namaLengkap String?
  role        String   @default("user") // admin, user
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}

model Notification {
  id          Int      @id @default(autoincrement())
  title       String
  message     String
  type        String   // INFO, SUCCESS, WARNING, DANGER
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("notifications")
}

model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("settings")
}